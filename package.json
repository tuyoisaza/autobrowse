{
  "name": "autobrowse",
  "version": "0.1.0",
  "description": "Local Browser Agent - Desktop app with API for browser automation",
  "main": "dist-electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "start": "npx tsx src/index.ts",
    "worker": "npx tsx src/worker/index.ts",
    "build:electron": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --outdir=dist-electron --external:electron --external:sql.js --external:playwright --format=esm --out-extension:.js=.mjs",
    "electron:dev": "npm run build:electron && npx electron .",
    "package": "npm run build:electron && npx @electron/packager . AutoBrowse --platform=win32 --arch=x64 --out=release --overwrite --ignore=\"(^/src$|^/electron$|^/docs$|^/.git$|node_modules/.cache)\" --prune=true"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "bull": "^4.12.0",
    "fastify": "^4.25.0",
    "ollama": "^0.6.3",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.0",
    "playwright": "^1.41.0",
    "sql.js": "^1.10.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@types/bull": "^4.10.0",
    "@types/node": "^20.10.0",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^9.0.0",
    "electron": "^28.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
